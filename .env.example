# Process Blueprint AI Workbench - MVP1 AI setup
#
# Keep all provider secrets server-side only. Do not create NEXT_PUBLIC_* API key
# variables and do not paste provider keys into the browser UI.

# Provider adapter. Supported values: mock, product-ai, openai, claude.
# Use mock for safe local fallback. Change to openai/claude/product-ai only after
# the matching server-side env values and approvals are configured.
AI_DEFAULT_PROVIDER=mock

# Legacy compatibility alias. Keep aligned with AI_DEFAULT_PROVIDER when used.
AI_PROVIDER=mock

# Shared fallback model name. Provider-specific model vars override this when set.
AI_MODEL=

# Deployment policy defaults. The browser UI still requires non-secret user
# consent before running cloud AI actions.
AI_ALLOW_CLOUD=false
AI_REQUIRE_APPROVAL=true

# Product AI server-side adapter. Required only when AI_DEFAULT_PROVIDER=product-ai.
PRODUCT_AI_BASE_URL=
PRODUCT_AI_ENDPOINT=
PRODUCT_AI_API_KEY=
PRODUCT_AI_DEFAULT_MODEL=
PRODUCT_AI_MODEL=

# OpenAI server-side adapter. Required only when AI_DEFAULT_PROVIDER=openai.
OPENAI_API_KEY=
OPENAI_DEFAULT_MODEL=
OPENAI_MODEL=

# Claude server-side adapter. Required only when AI_DEFAULT_PROVIDER=claude.
ANTHROPIC_API_KEY=
CLAUDE_DEFAULT_MODEL=
CLAUDE_MODEL=

# Mock provider identifier for local fallback.
MOCK_AI_MODEL=mock-local

# Feature flags. Defaults should stay false for mock/local fallback.
ENABLE_REAL_AI=false
ENABLE_REAL_AI_QA=false
ENABLE_REAL_AI_TEMPLATE_REVIEW=false

# Optional AI Orchestration V2 controls.
# Supported values: local-only, cloud-processing, no-training,
# organization-private-learning.
AI_DATA_USAGE_MODE=no-training
AI_PROVIDER_TIMEOUT_MS=45000
