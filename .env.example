# Process Blueprint AI Workbench - MVP1 AI setup
#
# Keep all provider secrets server-side only. Do not create NEXT_PUBLIC_* API key
# variables and do not paste provider keys into the browser UI.

# Provider adapter currently scaffolded for MVP1.
# Supported value: openai
AI_PROVIDER=openai

# Required only when a real AI feature flag below is enabled.
OPENAI_API_KEY=
AI_MODEL=

# Feature flags. Defaults should stay false for mock/local fallback.
ENABLE_REAL_AI=false
ENABLE_REAL_AI_QA=false
ENABLE_REAL_AI_TEMPLATE_REVIEW=false
