# Process Blueprint AI Workbench - MVP1 AI setup
#
# Keep all provider secrets server-side only. Do not create NEXT_PUBLIC_* API key
# variables and do not paste provider keys into the browser UI.

# Provider adapter. Supported values: mock, product-ai, openai, claude.
AI_PROVIDER=openai

# Shared fallback model name. Provider-specific model vars override this when set.
AI_MODEL=

# Product AI server-side adapter. Required only when AI_PROVIDER=product-ai.
PRODUCT_AI_ENDPOINT=
PRODUCT_AI_API_KEY=
PRODUCT_AI_MODEL=

# OpenAI server-side adapter. Required only when AI_PROVIDER=openai.
OPENAI_API_KEY=
OPENAI_MODEL=

# Claude server-side adapter. Required only when AI_PROVIDER=claude.
ANTHROPIC_API_KEY=
CLAUDE_MODEL=

# Mock provider identifier for local fallback.
MOCK_AI_MODEL=mock-local

# Feature flags. Defaults should stay false for mock/local fallback.
ENABLE_REAL_AI=false
ENABLE_REAL_AI_QA=false
ENABLE_REAL_AI_TEMPLATE_REVIEW=false
